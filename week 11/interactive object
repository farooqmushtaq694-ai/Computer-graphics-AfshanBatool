<!DOCTYPE html>
<html>
<head>
    <title>Interactive Square</title>

    <style>
        body{
            background:#fff0f5;
            text-align:center;
            font-family:Arial, sans-serif;
        }

        h2{
            color:#c71585;
        }

        canvas{
            border:2px solid #b03060;
            background:#ffe4ec;
        }
    </style>
</head>
<body>

<h2>Interactive Color Changing Square</h2>

<canvas id="myCanvas" width="500" height="350"></canvas>

<script>

let canvas = document.getElementById("myCanvas");
let ctx = canvas.getContext("2d");

let squareX = 220;
let squareY = 140;
let size = 60;

// NEW INITIAL COLOR
let squareColor = "#00bfff"; // deep sky blue

function drawSquare() {

    // clear canvas
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // background
    ctx.fillStyle = "#e6f7ff";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // square
    ctx.fillStyle = squareColor;
    ctx.fillRect(squareX, squareY, size, size);
}

drawSquare();

canvas.addEventListener("click", function() {

    let colors = [
        "#00bfff",   // deep sky blue
        "#1e90ff",   // dodger blue
        "#87cefa",   // light sky blue
        "#4682b4",   // steel blue
        "#20b2aa",   // light sea green
        "#7b68ee"    // medium slate blue
    ];

    squareColor = colors[Math.floor(Math.random() * colors.length)];

    drawSquare();
});

</script>

</body>
</html>
